# Copia este fichero como .env y rellena los valores reales
# cp .env.example .env

# ── Base de datos PostgreSQL ──────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=soluclon_test
DB_USER=soluclon_excel
DB_PASSWORD=tu_contraseña_aqui

# ── Configuración del árbol ───────────────────────────────
ROOT_PROCESS_ID=47201
ACEITE_EN_ORIGEN=15200

# ── Servidor ──────────────────────────────────────────────
PORT=3001

# ── CORS: URL de tu app en Vercel (en producción) ─────────
# Ejemplo: ALLOWED_ORIGIN=https://arbol-fabricaciones.vercel.app
ALLOWED_ORIGIN=*
